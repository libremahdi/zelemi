; Print "This is the End!" for X86_64-intel in binary
; See 'hello-world.mi'

CHK X86_64
NMB BIN ; Number Base

01001000 11000111 11000111 00000001 0 0 0   ; mov rdi, 1
01001000 10001101 00110101 00001101 0 0 0   ; lea rsi, [rip+15]
10111000 00000001 00000000 00000000 0       ; syscall 1
10111010 00010010 00000000 00000000 0       ; move edx, 18
00001111 00000101                           ; syscall
11000011                                    ; ret

1010100 1101000 1101001 1110011 100000 1101001 1110011 100000 1110100 1101000 1100101 100000 1000101 1101110 1100100 100001 1010 0

RUN


